# ── Server Config ──────────────────────────────────────
PORT=3000

# ── Email Config (Gmail SMTP) ─────────────────────────
# The email address that sends confirmation mails
GMAIL_USER=your-email@gmail.com

# Generate an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification enabled on the Google account)
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Admin email that receives contact notifications
ADMIN_EMAIL=admin@vizolane.com

# ── Google Sheets Config ──────────────────────────────
# The Sheet ID from the URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id

# Path to Google Cloud Service Account credentials JSON file
# Download from: Google Cloud Console → IAM & Admin → Service Accounts → Keys
GOOGLE_CREDENTIALS_PATH=./credentials.json

# ── CORS Config ───────────────────────────────────────
# Frontend URL (for CORS whitelist). Comma-separate multiple origins.
FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500
